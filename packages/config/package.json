{
  "name": "nest-config-mvp",
  "version": "0.0.0",
  "description": "Typed environment configuration for NestJS applications.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/node": "^25.6.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19"
  }
}
